---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Career">
  <header>
    <nav>
      <div class="brand">Soma Sugahara</div>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/career">Career</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="section">
      <h1>Career</h1>
      <p>This page outlines my background and professional journey.</p>

      <div class="card">
        <h3>Timeline</h3>
        <div class="timeline">
          <div class="timeline__item">
            <div class="timeline__date">2024</div>
            <div class="timeline__detail">
              <strong>Public servant</strong> — Working in local government administration.
            </div>
          </div>

          <div class="timeline__item">
            <div class="timeline__date">2023</div>
            <div class="timeline__detail">
              <strong>Certified Information Security Specialist</strong> (Registered Information Security Specialist).
            </div>
          </div>

          <div class="timeline__item">
            <div class="timeline__date">2022</div>
            <div class="timeline__detail">
              Graduated from <strong>Ritsumeikan University Cybersecurity Laboratory</strong> (Master’s, Information Science).
            </div>
          </div>

          <div class="timeline__item">
            <div class="timeline__date">2020</div>
            <div class="timeline__detail">
              Started research in cybersecurity and secure system design.
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3>Professional Interests</h3>
        <ul>
          <li>Security engineering</li>
          <li>Privacy-aware system design</li>
          <li>Tools that help organizations work safely and efficiently</li>
        </ul>
      </div>
    </section>
  </main>

  <footer class="footer">
    <p>© {new Date().getFullYear()} Soma Sugahara</p>
  </footer>
</BaseLayout>
